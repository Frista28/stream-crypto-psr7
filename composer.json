{
    "name": "frista28/stream-crypto-psr7",
    "type": "library",
    "description": "PSR-7 stream decorators for WhatsApp-like media encryption",
    "license": "MIT",
    "keywords": [
        "whatsapp",
        "crypto",
        "psr-7",
        "stream",
        "media"
    ],
    "homepage": "https://github.com/frista28/stream-crypto-psr7",
    "support": {
        "issues": "https://github.com/frista28/stream-crypto-psr7/issues",
        "source": "https://github.com/frista28/stream-crypto-psr7"
    },
    "autoload": {
        "psr-4": {
            "Frista28\\StreamCryptoPsr7\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Frista28\\StreamCryptoPsr7\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "guzzlehttp/psr7": "^2.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "stan": "vendor/bin/phpstan analyse",
        "cs:check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs:fix": "vendor/bin/php-cs-fixer fix",
        "check": [
            "@stan",
            "@cs:check",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
